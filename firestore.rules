rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to all documents for anyone (public storefront)
    match /{document=**} {
      allow read: if true;
    }
    // Users can read/write their own user doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Authenticated users can create orders
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.storeId != null
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    // Authenticated users can manage their addresses
    match /addresses/{addressId} {
      allow read, write: if request.auth != null;
    }
    // Anyone can read products; only authenticated users can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Anyone can read stores; only authenticated can create/update their own
    match /stores/{storeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    // Anyone can read public coupons; only authenticated can write
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Anyone can read ratings; authenticated can create
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
  }
}
